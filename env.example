# Copy to env.sh, fill in values, chmod 600 env.sh
# Confluence (Confluence admin + API token)
export CONFLUENCE_USERNAME='you@company.com'
export CONFLUENCE_API_TOKEN=''
export BASE_URL='https://your-site.atlassian.net'

# Coralogix Send-Your-Data API key + regional domain (no https://).
# This ships to POST https://ingress.<domain>/logs/v1/singles (Bearer auth) — current ingest API.
# The archived Docker image coralogixrepo/coralogix-audit-collector documented CORALOGIX_LOG_URL=.../api/v1/logs,
# which Coralogix is deprecating in favor of regional ingress + /logs/v1/singles (see Coralogix deprecation notices).
export CORALOGIX_PRIVATE_KEY=''
export CORALOGIX_DOMAIN='ap3.coralogix.com'
# Optional: full ingress URL only to infer region if DOMAIN is unset, e.g. https://ingress.eu2.coralogix.com/
# export CORALOGIX_LOG_URL=''

# Optional: rolling window for cron (e.g. every 5 minutes)
export INTEGRATION_SEARCH_DIFF_IN_MINUTES='5'
export CORALOGIX_APP_NAME='Confluence'
export INTEGRATION_NAME='confluence-audit'
