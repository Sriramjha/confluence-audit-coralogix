# Copy to env.sh, fill in values, chmod 600 env.sh
# Confluence (Confluence admin + API token)
export CONFLUENCE_USERNAME='you@company.com'
export CONFLUENCE_API_TOKEN=''
export BASE_URL='https://your-site.atlassian.net'

# Coralogix Send-Your-Data key + region (no https://)
export CORALOGIX_PRIVATE_KEY=''
export CORALOGIX_DOMAIN='ap3.coralogix.com'

# Optional: rolling window for cron (e.g. every 5 minutes)
export INTEGRATION_SEARCH_DIFF_IN_MINUTES='5'
export CORALOGIX_APP_NAME='Confluence'
export INTEGRATION_NAME='confluence-audit'
